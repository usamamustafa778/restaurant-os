# RestaurantOS Dashboard – env template
# Copy to .env and fill in real values. Do not commit .env.
# JWT_SECRET must match the backend .env JWT_SECRET.
# Admin login: see project root CREDENTIALS.md.

NEXT_PUBLIC_API_BASE_URL=http://localhost:5001
JWT_SECRET=your_long_random_jwt_secret_change_in_production

# Root domain for dashboard tenant routing (NOT the storefront domain).
# Local:  NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
# Live:   NEXT_PUBLIC_ROOT_DOMAIN=eatsdesk.com
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000

# Storefront domain (used in Website Settings to build the restaurant URL).
# Storefronts are deployed separately on eatsdesk.app.
# NEXT_PUBLIC_STOREFRONT_DOMAIN=eatsdesk.app

# Food discovery hub subdomain (must match DNS: food → same deployment as dashboard).
# Do not create a restaurant with subdomain "food".
# NEXT_PUBLIC_FOOD_HUB_SUBDOMAIN=food

# Thermal printer (ESC/POS over network).
# Set THERMAL_PRINTER_HOST to your printer's IP for silent printing (no browser dialog).
# If not set, the app falls back to browser window.print().
# To find your printer's IP: check printer settings or run `arp -a` on your network.
# Port 9100 is the standard for most thermal printers (Epson, Star, etc.)
# THERMAL_PRINTER_HOST=192.168.1.100
# THERMAL_PRINTER_PORT=9100
